# MCP Index Ignore Patterns
# One pattern per line, supports gitignore syntax

# Version control
.git/
.svn/

# Dependencies
node_modules/
vendor/
venv/
.env/
__pycache__/
*.pyc

# Build outputs
dist/
build/
target/
*.min.js
*.min.css

# IDE files
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# External fixture repos (not project source)
test_workspace/
baml_client/

# Documentation (optional - remove if you want to index docs)
# docs/
# *.md

# Benchmark artifacts (contain literal query strings that pollute BM25)
docs/benchmarks/
fast_test_results/fast_report_*.md
coverage.xml
htmlcov/

# Large files
*.zip
*.tar.gz
*.iso
*.exe
*.dll
*.so
*.dylib

# Temporary files
*.tmp
*.temp
*.log
