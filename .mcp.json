{
  "mcpServers": {
    "code-index-mcp": {
      "command": "op",
      "args": [
        "run",
        "--no-masking",
        "--env-file=/home/viperjuice/code/Code-Index-MCP/.mcp.env",
        "--",
        "/home/viperjuice/code/Code-Index-MCP/.venv/bin/python3",
        "-m",
        "mcp_server.cli",
        "stdio"
      ],
      "cwd": "/home/viperjuice/code/Code-Index-MCP",
      "env": {
        "PYTHONPATH": "/home/viperjuice/code/Code-Index-MCP",
        "MCP_WORKSPACE_ROOT": "/home/viperjuice/code/Code-Index-MCP",
        "MCP_INDEX_STORAGE_PATH": "/home/viperjuice/code/Code-Index-MCP/.indexes",
        "MCP_REPO_REGISTRY": "/home/viperjuice/code/Code-Index-MCP/.indexes/repository_registry.json",
        "MCP_INDEX_PATHS": "/home/viperjuice/code/Code-Index-MCP",
        "MCP_ENABLE_MULTI_REPO": "true",
        "MCP_ENABLE_MULTI_PATH": "true",
        "SEMANTIC_SEARCH_ENABLED": "true",
        "OPENAI_API_KEY": "local",
        "OPENAI_API_BASE": "http://ai:8001/v1",
        "CEREBRAS_MODEL": "gpt-oss-120b",
        "MCP_LOG_PATH": "/home/viperjuice/.mcp/logs",
        "MCP_TEMP_PATH": "/tmp",
        "MCP_DATA_PATH": "/home/viperjuice/code/Code-Index-MCP/data"
      }
    }
  }
}
