{
  "mcpServers": {
    "code-index-native": {
      "command": "mcp-index",
      "args": ["stdio"],
      "cwd": "${workspace}",
      "env": {
        "PYTHONPATH": "${workspace}",
        "VOYAGE_API_KEY": "${VOYAGE_API_KEY:-}",
        "SEMANTIC_SEARCH_ENABLED": "${SEMANTIC_SEARCH_ENABLED:-false}",
        "MCP_WORKSPACE_ROOT": "${workspace}",
        "MCP_LOG_LEVEL": "${MCP_LOG_LEVEL:-INFO}",
        "DATABASE_URL": "sqlite:///./code_index.db"
      }
    }
  }
}
