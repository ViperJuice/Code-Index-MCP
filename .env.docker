# Docker environment configuration
MCP_WORKSPACE_ROOT=/app
MCP_INDEX_STORAGE_PATH=/app/.indexes
MCP_REPO_REGISTRY=/app/.indexes/repository_registry.json
MCP_PYTHON_PATH=/usr/local/bin/python
MCP_LOG_PATH=/var/log/mcp-server
MCP_TEMP_PATH=/tmp
MCP_DATA_PATH=/app/data
MCP_ENABLE_MULTI_REPO=true
MCP_ENABLE_MULTI_PATH=true
MCP_AUTO_DETECT_LANGUAGES=true
MCP_LANGUAGE_DETECT_MAX_FILES=5000
MCP_LANGUAGE_DETECT_MIN_FILES=2
MCP_FAST_STARTUP=true
SEMANTIC_SEARCH_ENABLED=true
SEMANTIC_AUTOSTART_QDRANT=true
SEMANTIC_STRICT_MODE=false
SEMANTIC_PREFLIGHT_TIMEOUT_SECONDS=10
QDRANT_COMPOSE_FILE=docker-compose.qdrant.yml
OPENAI_API_BASE=http://localhost:8001/v1
