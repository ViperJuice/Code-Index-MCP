# Copy to .mcp.env (gitignored). These are 1Password secret references, not secrets.
# Resolved at MCP spawn time by `op run --env-file=.mcp.env`.
# Requires OP_SERVICE_ACCOUNT_TOKEN exported in the shell.

# Replace vault + UUID with your own. Use UUIDs (not names) because op://
# refs don't accept spaces, parens, or em-dashes in item names.
#   op item list --vault <vault> --format=json | jq '.[] | {id, title}'

VOYAGE_API_KEY=op://<vault>/<voyage-item-uuid>/credential
CEREBRAS_API_KEY=op://<vault>/<cerebras-item-uuid>/credential
